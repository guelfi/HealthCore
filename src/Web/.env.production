# 🚀 Configurações de Produção - HealthCore Frontend
# Oracle Cloud Infrastructure (OCI) Production Environment

# ====================================================================
# PRODUÇÃO - ORACLE CLOUD INFRASTRUCTURE
# ====================================================================
# IP Público da instância OCI
# Em producao/local usamos o proxy relativo /healthcore/api
VITE_API_BASE_URL=/healthcore/api
VITE_API_BASE_URL_NETWORK=/healthcore/api
VITE_API_URL=/healthcore/api

# ====================================================================
# CONFIGURAÇÕES DA APLICAÇÃO
# ====================================================================
# Ambiente de produção
VITE_APP_NAME=HealthCore
VITE_APP_VERSION=1.0.0
VITE_APP_ENVIRONMENT=production

# Debug desabilitado em produção
VITE_ENABLE_DEBUGGER=false
VITE_ENABLE_CONSOLE_LOGS=false
VITE_ENABLE_PERFORMANCE_MONITOR=false

# API Configuration para produção
VITE_API_BASE_URL=/healthcore/api
VITE_API_TIMEOUT=15000

# Feature flags para produção
VITE_ENABLE_MOCK_DATA=false
VITE_ENABLE_DEBUG_ROUTING=false

# ====================================================================
# CONFIGURAÇÕES DE PRODUÇÃO
# ====================================================================
VITE_DEV_MODE=false
VITE_DEBUG_MODE=false
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_REPORTING=true

# ====================================================================
# CONFIGURAÇÕES DE SEGURANÇA
# ====================================================================
VITE_SECURE_COOKIES=true
VITE_ENABLE_HTTPS_REDIRECT=false

# ====================================================================
# CONFIGURAÇÕES DE PERFORMANCE
# ====================================================================
VITE_ENABLE_SERVICE_WORKER=true
VITE_ENABLE_COMPRESSION=true
VITE_CACHE_DURATION=3600

# ====================================================================
# CONFIGURAÇÕES DE TIMEOUT
# ====================================================================
VITE_API_TIMEOUT=30000
