{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Error",
      "Microsoft.EntityFrameworkCore": "Error",
      "System": "Error"
    }
  },
  "AllowedHosts": "healthcore.batuara.net;localhost;127.0.0.1",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=/app/database/healthcore.db;Cache=Shared;Foreign Keys=true;"
  },
  "Jwt": {
    "Issuer": "HealthCore.Api",
    "Audience": "HealthCore.Client",
    "ExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "RateLimiting": {
    "Auth": {
      "PermitLimit": 10,
      "WindowMinutes": 5
    }
  },
  "Security": {
    "EnableSecurityHeaders": true,
    "RequireHttps": false,
    "RefreshCookieSecure": true
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "OpenApi": {
    "Enabled": false
  },
  "HealthChecks": {
    "MaxMemoryUsageMB": 512,
    "MinDiskSpaceGB": 1,
    "DatabaseTimeoutSeconds": 30
  }
}